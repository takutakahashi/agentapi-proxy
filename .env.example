# using PAT
#export GITHUB_TOKEN=xxxxxxxxxxxx

# or GitHub App
#export GITHUB_APP_PEM_PATH=/path/to/github_app.pem
#export GITHUB_APP_ID=123

# recommended using --dangerously-skip-permissions, and you can add any other args
export CLAUDE_ARGS="--dangerously-skip-permissions"

# External session manager allocator mode (Proxy B -> Proxy A outbound polling)
#export SESSION_MANAGER_UPSTREAM_URL=https://proxy-a.example.com
#export SESSION_MANAGER_CONNECTION_TOKEN=generated-token-from-proxy-a-settings
